# LeanTacticLatencyBench — example configuration
#
# Copy to `config.env` (or your shell rc) and `source` before running an
# LLM-backed agent:
#
#     cp config.example.env config.env
#     # edit config.env, fill in your real keys
#     source config.env
#     python3 scripts/run_agent.py --agent agents/llm_openai.py --budget 180
#
# `config.env` is gitignored (see `.gitignore`).

# ─── OpenAI API (used by `agents/llm_openai.py`) ──────────────────────
# The OpenAI agent prefers reading the key from a *file*, not an env
# var, so it never lands in shell history. The default search order is:
#
#   1. --api-key-file <path>                   (CLI flag)
#   2. $OPENAI_API_KEY                         (env var)
#   3. <project_root>/api                      (LeanTacticLatencyBench/api)
#   4. <project_root>/../api                   (this repo's layout)
#
# Recommended setup: drop your key in a single-line file and protect it.
#
#     printf '%s' 'sk-proj-...' > ../api      # one line, no trailing newline
#     chmod 600 ../api                         # owner-only
#
# Pattern matched by .gitignore so it can never be committed.
#
# Optional env-var fallback:
# export OPENAI_API_KEY="sk-proj-REPLACE-ME"

# Optional — override the default model. Defaults to `gpt-4o`.
# export OPENAI_MODEL="gpt-4o-mini"

# ─── Anthropic API (used by `agents/llm_claude.py`) ──────────────────
# Optional — only needed if you want to use the Claude-backed agent.
# Without this set, llm_claude.py exits 2 and the orchestrator records
# every problem as UNSOLVED.
# export ANTHROPIC_API_KEY="sk-ant-api03-REPLACE-ME"

# Optional — override the default Claude model.
# Defaults to `claude-opus-4-7`.
# export ANTHROPIC_MODEL="claude-sonnet-4-6"

# ─── Agent prompt ─────────────────────────────────────────────────────
# Each LLM agent reads its system prompt from a file by default:
#     agents/prompts/llm_openai_default.txt   (used by llm_openai.py)
#     agents/prompts/llm_claude_default.txt   (used by llm_claude.py)
# Override per-run with --system-prompt-file <path>, or globally:
# export LATB_SYSTEM_PROMPT_FILE="agents/prompts/my_custom_prompt.txt"

# ─── Budgets ──────────────────────────────────────────────────────────
# Per-problem wall-clock cap, in seconds. CLI flag `--budget` overrides.
# export LATB_DEFAULT_BUDGET=120
